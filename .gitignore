# ==============================
# SECRETS — NEVER COMMIT THESE
# ==============================

# Android signing
android/key.properties
*.keystore
*.jks

# Environment files
.env
.env.local
.env.*.local
*.env

# Firebase / Google Services (contain API keys)
# Uncomment if you don't want these in the repo:
# android/app/google-services.json
# ios/Runner/GoogleService-Info.plist

# iOS provisioning profiles
*.mobileprovision
*.p12

# macOS keychain
*.keychain
*.keychain-db

# Gemini / Antigravity agent data
.gemini/

# Pods (can be regenerated with `cd ios && pod install`)
# Uncomment the line below if you want to exclude Pods from git
# ios/Pods/

# Play Store Keys
android/app/*-keystore.jks
android/key.properties
